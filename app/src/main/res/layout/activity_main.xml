<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Превью камеры -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Canvas для рисования -->
    <com.handdraw.app.DrawingView
        android:id="@+id/drawingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Верхняя панель -->
    <LinearLayout
        android:id="@+id/topPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        android:background="@drawable/rounded_button">

        <!-- Статус точка 1 -->
        <View
            android:id="@+id/statusDot1"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/status_dot_inactive" />

        <!-- Статус точка 2 -->
        <View
            android:id="@+id/statusDot2"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/status_dot_inactive" />

        <!-- Текст режима -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Ожидание..."
            android:textColor="#CCCCCC"
            android:textSize="12sp" />

        <!-- FPS -->
        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="0 fps"
            android:textColor="#888888"
            android:textSize="11sp" />

        <!-- Цвета -->
        <View
            android:id="@+id/colorRed"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="12dp"
            android:background="@color/red" />

        <View
            android:id="@+id/colorGreen"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@color/green" />

        <View
            android:id="@+id/colorBlue"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@color/blue" />

        <View
            android:id="@+id/colorOrange"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@color/orange" />

        <View
            android:id="@+id/colorWhite"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@color/white" />

        <View
            android:id="@+id/colorPurple"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="4dp"
            android:background="@color/purple" />
    </LinearLayout>

    <!-- Подсказка -->
    <TextView
        android:id="@+id/hintText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="80dp"
        android:text="☝️ Указательный — рисовать | 👌 Щипок — перетащить | ✋ Ладонь — пауза"
        android:textColor="#AAAAAA"
        android:textSize="10sp"
        android:background="@drawable/rounded_button"
        android:paddingHorizontal="14dp"
        android:paddingVertical="8dp" />

    <!-- Нижние кнопки -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnClear"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗑️ Очистить"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="@drawable/rounded_button"
            android:layout_marginEnd="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="↩️ Отмена"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="@drawable/rounded_button"
            android:layout_marginEnd="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp" />

        <Button
            android:id="@+id/btnThickness"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🖊️ Толщина"
            android:textSize="13sp"
            android:textColor="@color/white"
            android:background="@drawable/rounded_button"
            android:minHeight="0dp"
            android:minWidth="0dp" />
    </LinearLayout>

    <!-- Экран загрузки -->
    <FrameLayout
        android:id="@+id/loadingScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:indeterminateTint="@color/purple" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Загрузка модели рук..."
                android:textColor="#AAAAAA"
                android:textSize="14sp" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
